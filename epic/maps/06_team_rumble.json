{
  "template": "team-rumble",
  "version": "1.0.0",
  "uefn_version": ">=31.0",
  "display_name": "Team Rumble — Combate em Equipe com Respawn",
  "description": "12v12 com respawn infinito. Primeiro time a atingir 100 eliminações vence. Loot aéreo e baúes abundantes. Ideal para partidas casuais e grind de desafios.",
  "tags": ["team-rumble", "pvp", "casual", "12v12", "respawn", "large-team"],

  "island": {
