    {"type": "supply_drop_controller", "interval_sec": 90, "drop_count": 3},
    {"type": "team_settings", "team_count": 2, "team_size": 12, "fill_enabled": true},
    {"type": "scoreboard", "visible": true, "sort_by": "eliminations"},
    {"type": "item_spawner", "positions": "auto-distributed", "count": 200}
