    "tier_weights": {"common": 20, "uncommon": 35, "rare": 30, "epic": 12, "legendary": 3},
    "vehicles": ["whiplash", "atk", "shopping_cart", "quadcrasher"]
  },

  "pois": [
    {"id": "zone_a", "name": "Zona A", "type": "mixed", "size_tier": "large", "chests": 20},
    {"id": "zone_b", "name": "Zona B", "type": "forest", "size_tier": "medium", "chests": 15},
    {"id": "zone_c", "name": "Zona C", "type": "desert", "size_tier": "medium", "chests": 14},
    {"id": "zone_d", "name": "Zona D", "type": "industrial", "size_tier": "small", "chests": 10},
    {"id": "zone_e", "name": "Zona E", "type": "snow", "size_tier": "medium", "chests": 16},
    {"id": "center", "name": "Centro", "type": "urban", "size_tier": "medium", "chests": 12}
